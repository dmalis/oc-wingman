{
  "name": "oc-wingman",
  "version": "0.1.1",
  "description": "Standalone OpenCode Wingman reviewer plugin",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./tui": {
      "types": "./src/tui/index.ts",
      "default": "./src/tui/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "opencode-plugin",
    "wingman",
    "review",
    "second-opinion"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "*",
    "@types/node": "^25.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test"
  }
}
